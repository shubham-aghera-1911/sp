{
  "name": "student-productivity-os",
  "version": "1.0.0",
  "description": "A comprehensive MERN stack application for college students to manage their academic life",
  "scripts": {
    "install-all": "cd server && npm install && cd ../client && npm install",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": [
    "student",
    "productivity",
    "MERN",
    "education",
    "assignment-tracker",
    "exam-countdown",
    "attendance-tracker"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "concurrently": "^8.0.0",
    "tailwindcss": "^4.3.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.23.0",
    "mongoose": "^9.7.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "vite": "^8.1.3"
  }
}
