# MongoDB connection string (local or MongoDB Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/taskflow

# Secret used to sign JWT tokens - use a long random string in production
JWT_SECRET=replace_this_with_a_long_random_secret

# Port the API server runs on
PORT=5000

# This server's own public URL — used to build the OAuth callback URLs below.
# Change this to your deployed backend URL in production.
SERVER_URL=http://localhost:5000

# Comma-separated list of allowed frontend origins. The first one is also used
# for password-reset links and OAuth redirects.
CLIENT_URL=http://localhost:5173

# --- Google OAuth (optional) ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {SERVER_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth (optional) ---
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: {SERVER_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- SMTP (optional, required for "forgot password" emails) ---
# For local testing, https://mailtrap.io gives you a free sandbox SMTP inbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=TaskFlow <no-reply@taskflow.app>
